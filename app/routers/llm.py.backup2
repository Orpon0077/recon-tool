from app.services.recon_service import scan_ports
from fastapi import APIRouter, HTTPException
from pydantic import BaseModel
from typing import Optional
import uuid
import asyncio
import re
from datetime import datetime
from app.llm_provider import llm_provider
from app.services.recon_service import scan_ports  # আপনার recon service ইম্পোর্ট করুন

router = APIRouter(prefix="/api/llm", tags=["llm"])

class ChatRequest(BaseModel):
    prompt: str
    session_id: Optional[str] = None

class ChatResponse(BaseModel):
    response: str
    session_id: str
    provider: Optional[str] = None
    scan_id: Optional[str] = None

# In-memory storage
conversations = {}
conversation_history = {}

def parse_scan_command(prompt: str):
    """Parse scan commands from user prompt"""
    prompt_lower = prompt.lower()
    
    # Check for port scan
    if "port scan" in prompt_lower or "scan ports" in prompt_lower or "port" in prompt_lower:
        # Extract domain
        domain_match = re.search(r'(?:scan|for|of)?\s*([a-zA-Z0-9][a-zA-Z0-9-]{1,61}[a-zA-Z0-9]\.[a-zA-Z]{2,})', prompt)
        if domain_match:
            domain = domain_match.group(1)
            return {
                "action": "port_scan",
                "target": domain
            }
    
    # Check for full scan
    if "full scan" in prompt_lower:
        domain_match = re.search(r'full scan\s*([a-zA-Z0-9][a-zA-Z0-9-]{1,61}[a-zA-Z0-9]\.[a-zA-Z]{2,})', prompt_lower)
        if domain_match:
            domain = domain_match.group(1)
            return {
                "action": "full_scan",
                "target": domain
            }
    
    return None

@router.post("/chat")
async def chat(request: ChatRequest):
    print("[LLM_ROUTER] /chat endpoint hit!")
    print("[LLM_ROUTER] Prompt:", request.prompt)

    session_id = request.session_id or str(uuid.uuid4())
    
    # Initialize conversation storage
    if session_id not in conversations:
        conversations[session_id] = []
        conversation_history[session_id] = {
            "session_id": session_id,
            "created_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "messages": []
        }
    
    # Store user message
    conversations[session_id].append({
        "role": "user",
        "content": request.prompt
    })
    
    # Check if this is a scan command
    scan_command = parse_scan_command(request.prompt)
    response_text = ""
    scan_id = None
    
    if scan_command:
        print(f"[LLM_ROUTER] Detected scan command: {scan_command}")
        
        if scan_command["action"] == "port_scan":
            try:
                # Call actual port scan function
                print(f"[LLM_ROUTER] Starting port scan for {scan_command['target']}")
                ports_result = await scan_ports(scan_command["target"])
                
                if ports_result and ports_result.get("open_ports"):
                    response_text = f"🔍 Port scan completed for {scan_command['target']}:\n\n"
                    response_text += f"📊 Open Ports Found: {len(ports_result['open_ports'])}\n\n"
                    
                    for port in ports_result['open_ports'][:20]:  # Show first 20
                        response_text += f"  • Port {port['port']}/{port.get('protocol', 'tcp')} - {port.get('service', 'Unknown')}\n"
                    
                    if len(ports_result['open_ports']) > 20:
                        response_text += f"\n  ... and {len(ports_result['open_ports']) - 20} more ports"
                    
                    scan_id = ports_result.get('scan_id')
                else:
                    response_text = f"✅ Port scan completed for {scan_command['target']}. No open ports found."
                    
            except Exception as e:
                response_text = f"❌ Port scan failed: {str(e)}"
        
        elif scan_command["action"] == "full_scan":
            response_text = f"🔄 Starting full reconnaissance scan for {scan_command['target']}...\n\nThis may take a few minutes. You'll see results in the dashboard."
            # You can add full scan logic here
    
    else:
        # Regular LLM chat (no scan command)
        result = await asyncio.to_thread(
            llm_provider.chat,
            [{"role": "user", "content": request.prompt}]
        )
        
        print("[LLM_ROUTER] Result:", result)
        
        if result.get("success"):
            response_text = result["response"]
        else:
            response_text = f"Error: {result.get('error', 'Unknown error')}"
    
    # Store assistant response
    conversations[session_id].append({
        "role": "assistant",
        "content": response_text
    })
    conversation_history[session_id]["messages"] = conversations[session_id]
    
    return ChatResponse(
        response=response_text,
        session_id=session_id,
        provider="local",
        scan_id=scan_id
    )

@router.get("/history")
async def get_chat_history():
    try:
        history_list = []
        for session_id, data in conversation_history.items():
            messages = data.get("messages", [])
            preview = "New conversation"
            if messages:
                first_msg = messages[0].get("content", "")
                preview = first_msg[:50] if len(first_msg) > 50 else first_msg
            
            history_list.append({
                "session_id": session_id,
                "preview": preview,
                "created_at": data.get("created_at", datetime.now().strftime("%Y-%m-%d %H:%M:%S")),
                "message_count": len(messages)
            })
        
        history_list.sort(key=lambda x: x["created_at"], reverse=True)
        return {"conversations": history_list}
    except Exception as e:
        print(f"[LLM_ROUTER] History error: {e}")
        return {"conversations": []}

@router.get("/history/{session_id}")
async def get_conversation(session_id: str):
    try:
        if session_id not in conversation_history:
            raise HTTPException(status_code=404, detail="Conversation not found")
        
        return {
            "messages": conversation_history[session_id].get("messages", [])
        }
    except Exception as e:
        print(f"[LLM_ROUTER] Get conversation error: {e}")
        raise HTTPException(status_code=500, detail=str(e))