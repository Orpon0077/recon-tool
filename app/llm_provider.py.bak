# ── LLM Provider (Hugging Face) ────────────────────────────
import os
import requests
import time
from dotenv import load_dotenv

load_dotenv()

class LLMProvider:
    def __init__(self):
        self.api_key = os.getenv("HUGGINGFACE_API_KEY", "")
        # ── Free & Fast Models ──
        self.models = [
            "google/flan-t5-large",
            "microsoft/DialoGPT-medium",
            "microsoft/phi-2",
        ]
        self.current_model = self.models[0]
        print("[LLM] ✅ Hugging Face initialized")
    
    def chat(self, messages):
        try:
            user_message = ""
            for msg in messages:
                if msg.get("role") == "user":
                    user_message = msg.get("content", "")
            
            if not user_message:
                return {"error": "No user message"}
            
            if not self.api_key:
                return {"error": "HUGGINGFACE_API_KEY not set"}
            
            start = time.time()
            
            # ── Try models one by one ──
            for model in self.models:
                try:
                    url = f"https://api-inference.huggingface.co/models/{model}"
                    headers = {"Authorization": f"Bearer {self.api_key}"}
                    payload = {"inputs": user_message}
                    
                    response = requests.post(url, json=payload, headers=headers, timeout=30)
                    data = response.json()
                    
                    if response.status_code == 200:
                        if isinstance(data, list) and len(data) > 0:
                            text = data[0].get("generated_text", "")
                        elif isinstance(data, dict):
                            text = data.get("generated_text", "")
                        else:
                            text = str(data)
                        
                        elapsed = time.time() - start
                        print(f"[LLM] Hugging Face ({model}) response: {elapsed:.2f}s")
                        
                        if text and len(text) > 5:
                            return {"success": True, "response": text[:500]}
                    else:
                        print(f"[LLM] {model} failed: {data}")
                except Exception as e:
                    print(f"[LLM] {model} error: {e}")
                    continue
            
            return {"error": "All Hugging Face models failed"}
            
        except Exception as e:
            print(f"[LLM] Error: {e}")
            return {"error": str(e)}

llm_provider = LLMProvider()
